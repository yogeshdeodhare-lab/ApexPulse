{
  "name": "ai-finops-claude",
  "version": "10.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/seed.ts",
    "db:setup": "prisma db push && tsx scripts/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx scripts/seed.ts",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "auth:hash-password": "tsx scripts/hash-password.ts",
    "docker:build": "docker build -t apex-pulse .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "next": "^15.3.0",
    "next-auth": "^4.24.10",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.15.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
