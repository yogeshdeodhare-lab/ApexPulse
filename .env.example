# ─────────────────────────────────────────────────────────────────────────────
# APEX Pulse — Environment Configuration
# Copy to .env.local (dev) or inject as container env vars (prod).
# All provider keys are OPTIONAL — the dashboard runs on seed data without them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, works out of the box for dev/single-node):
DATABASE_URL="file:./prisma/dev.db"

# PostgreSQL (recommended for production — enables multi-replica):
# DATABASE_URL="postgresql://apex:password@db:5432/apex_pulse?sslmode=require"

# ── Key Vault (S11) — encrypts API keys stored via Integrations page ─────────
# Generate: openssl rand -base64 32
# Required in production. Without it, dev uses an insecure fallback (warns).
ENCRYPTION_KEY=replace-with-openssl-rand-base64-32

# ── Auth (NextAuth v4) ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Required for login to work. Without this, the app runs in open mode (no auth).
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Set to your public URL (no trailing slash). Required when deploying.
# Examples: https://apex.yourcompany.com  |  https://apex-pulse.example.org
NEXTAUTH_URL=https://your-domain.com

# Expose auth status to client-side (set to "1" when NEXTAUTH_SECRET is configured)
NEXT_PUBLIC_AUTH_ENABLED=1

# ── Bootstrap admin (credentials login — used before DB users are created) ────
# These are only checked when NEXTAUTH_SECRET is set.
# Remove after first login and creating a DB admin user.
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-me-immediately

# ── GitHub OAuth (optional — activate when both vars are set) ─────────────────
# Create at: https://github.com/settings/applications/new
# Authorization callback URL: https://your-domain.com/api/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# NEXT_PUBLIC_GITHUB_OAUTH_ENABLED=1

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Default: 120 requests per minute per IP address.
# RATE_LIMIT_RPM=120

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required for the Live Demo tab and recording Claude API calls.
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── GitHub (for Copilot seat data) ────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── Alert Webhooks ────────────────────────────────────────────────────────────
# Slack incoming webhook — fires once per new alert (not each poll)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Generic HTTP webhook — receives JSON alerts for any endpoint
ALERT_WEBHOOK_URL=https://your-webhook-endpoint.com/alerts
